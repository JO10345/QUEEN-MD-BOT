# ──────────────────────────────────────────
#  Queen MD Bot — Environment Configuration
# ──────────────────────────────────────────

# Your WhatsApp number (with country code, no + or spaces)
PHONE_NUMBER=

# Bot display name
BOT_NAME=Queen MD Bot

# Command prefix (default: !)
PREFIX=!

# Your WhatsApp number (for owner-only commands)
OWNER_NUMBER=

# Owner display name shown in the help menu
OWNER_NAME=Owner

# Credit shown after "Crafted by:" in the help menu
CREATED_BY=TECH

# Bot bio shown on profile
BOT_BIO=👑 Queen MD Bot | !help for commands

# Bot version shown in !botinfo
BOT_VERSION=2.0.0

# URL to bot's profile picture (shown above the help menu)
BOT_IMAGE_URL=https://i.ibb.co/XZCzdqZk/IMG-20260416-WA0140.jpg

# ── AI Chat & Image Generation ─────────────────────
# Get free key at: https://platform.openai.com/api-keys
# (AI works WITHOUT this key — it uses a free Gemini proxy by default)
OPENAI_API_KEY=

# AI model (default: gemini — uses free proxy, no key needed)
AI_MODEL=gemini

# Max conversation history per user
AI_HISTORY_LIMIT=20

# ── News ────────────────────────────────────────────
# Get free key at: https://gnews.io (100 requests/day free)
NEWS_API_KEY=

# ── Music Providers ─────────────────────────────────
MUSIC_PROVIDERS=ytdl,cobalt
COBALT_API_URL=
MUSIC_API_URL=

# ── Auto-React ──────────────────────────────────────
AUTOREACT_PM_ENABLED=true
AUTOREACT_GROUP_ENABLED=false

# ── Chatbot (AI auto-reply) ─────────────────────────
CHATBOT_PM_ENABLED=true
CHATBOT_GROUP_ENABLED=false

# ── Update from GitHub ────────────────────────────
GITHUB_REPO=JO10345/QUEEN-MD-BOT
GITHUB_BRANCH=main

# ── AI Image Generation ─────────────────────────────
IMAGINE_PROVIDER=pollinations
POLLINATIONS_MODEL=flux
POLLINATIONS_WIDTH=1024
POLLINATIONS_HEIGHT=1024

# ── YouTube API ─────────────────────────────────────
YTAPI_BASE=https://eliteprotech-apis.zone.id

# ── Feature Toggles (set to false to disable) ───────
MUSIC_ENABLED=true
YOUTUBE_ENABLED=true
WEATHER_ENABLED=true
AI_ENABLED=true
STICKER_ENABLED=true
TRANSLATE_ENABLED=true
GROUP_ENABLED=true
REMINDER_ENABLED=true
IMAGINE_ENABLED=true
CALC_ENABLED=true
CURRENCY_ENABLED=true
NEWS_ENABLED=true
FUN_ENABLED=true
POLL_ENABLED=true
QUIZ_ENABLED=true
IMAGE_ENABLED=true
CUTE_ENABLED=true

# ── Debug ────────────────────────────────────────────
DEBUG=false
