# ──────────────────────────────────────────
#  Queen MD Bot — Environment Configuration
# ──────────────────────────────────────────

# Your WhatsApp number (with country code, no + or spaces)
PHONE_NUMBER=923120754178

# Bot display name
BOT_NAME=Queen MD Bot

# Command prefix (default: !)
PREFIX=!

# Your WhatsApp number (for owner-only commands)
OWNER_NUMBER=923120754178

# Owner display name shown in the help menu (decorated automatically)
OWNER_NAME=fizu

# Credit shown after "Crafted by:" in the help menu
CREATED_BY=TECH

# Bot bio shown on profile
BOT_BIO=👑 Queen MD Bot | !help for commands

# Bot version shown in !botinfo
BOT_VERSION=2.0.0

# URL to bot's profile picture (also shown above the help menu)
BOT_IMAGE_URL=https://i.ibb.co/XZCzdqZk/IMG-20260416-WA0140.jpg

# ── AI Chat & Image Generation ─────────────────────
# Get free key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AI model (default: gpt-3.5-turbo, or gpt-4)
AI_MODEL=gpt-3.5-turbo

# Max conversation history per user
AI_HISTORY_LIMIT=20

# ── News ────────────────────────────────────────────
# Get free key at: https://gnews.io (100 requests/day free)
NEWS_API_KEY=your_gnews_api_key_here

# ── Music Providers ─────────────────────────────────
# Order to try (ytdl, cobalt, custom)
MUSIC_PROVIDERS=ytdl,cobalt

# Optional: Cobalt API URL (defaults to api.cobalt.tools)
COBALT_API_URL=

# Optional: Your own custom music API URL
MUSIC_API_URL=

# ── Auto-React ──────────────────────────────────────
# React with random emoji to incoming messages.
# PM (DMs) defaults ON, groups default OFF.
AUTOREACT_PM_ENABLED=true
AUTOREACT_GROUP_ENABLED=false

# Custom emoji list (comma-separated, WhatsApp supported only)
# AUTOREACT_EMOJIS=❤️,👍,🔥,😂

# ── Chatbot (AI auto-reply) ─────────────────────────
# When ON, the bot replies to non-command messages using the AI API.
# In groups, it replies only when @mentioned or replied-to.
# Toggle live via:  !chatbot pm on/off  |  !chatbot group on/off
# Toggles persist across restarts in state.json.
CHATBOT_PM_ENABLED=true
CHATBOT_GROUP_ENABLED=false

# ── Update from GitHub (!update command) ────────────
# Owner runs !update to pull the latest version from your GitHub repo.
# Format: username/repository
GITHUB_REPO=JO10345/QUEEN-MD-BOT
GITHUB_BRANCH=main
# Only required for PRIVATE repositories
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ── REQUIREMENT: ffmpeg ─────────────────────────────
# Install ffmpeg so downloaded YouTube videos play inline on WhatsApp.
#   • Ubuntu/Debian:  sudo apt install ffmpeg
#   • macOS:          brew install ffmpeg
#   • Termux:         pkg install ffmpeg
# Without ffmpeg, videos are sent as files (still openable, just not inline).

# ── AI Image Generation ─────────────────────────────
# Provider: pollinations (FREE, default) or openai (requires API key)
IMAGINE_PROVIDER=pollinations
POLLINATIONS_MODEL=flux
POLLINATIONS_WIDTH=1024
POLLINATIONS_HEIGHT=1024

# ── Feature Toggles (set to false to disable) ───────
MUSIC_ENABLED=true
YOUTUBE_ENABLED=true
WEATHER_ENABLED=true
AI_ENABLED=true
STICKER_ENABLED=true
TRANSLATE_ENABLED=true
GROUP_ENABLED=true
REMINDER_ENABLED=true
IMAGINE_ENABLED=true
CALC_ENABLED=true
CURRENCY_ENABLED=true
NEWS_ENABLED=true
FUN_ENABLED=true
POLL_ENABLED=true
QUIZ_ENABLED=true
IMAGE_ENABLED=true
CUTE_ENABLED=true

# ── YouTube / Music download API ──────────────────
# EliteProTech API gives direct H.264 MP4 + MP3 links — no transcoding needed.
YTAPI_BASE=https://eliteprotech-apis.zone.id

# ── Debug ────────────────────────────────────────────
DEBUG=false
